/* 全局 */
QWidget {
    background-color: #ffffff;
    color: #2b2b2b;
    font-family: "Microsoft YaHei UI", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 14px;
}

/* 主窗口 */
QMainWindow {
    background-color: #ffffff;
}

/* 左侧最细导航栏 */
#sidebar {
    background-color: #f6f5f1;
    border-right: 1px solid #e5e3dd;
}

#sidebar QPushButton {
    background: transparent;
    border: none;
    border-radius: 8px;
    padding: 10px;
    color: #666666;
    font-weight: bold;
}
#sidebar QPushButton:hover {
    background-color: #ebe9e4;
    color: #2b2b2b;
}
#sidebar QPushButton[active="true"] {
    background-color: #ffffff;
    color: #cc6655; /* Claude 标志性的砖橙色 */
    border: 1px solid #e5e3dd;
}

/* Spaces Panel (第二级列表导航栏) */
#spaces_panel {
    background-color: #faf9f7;
    border-right: 1px solid #e5e3dd;
}
#spaces_panel QLabel {
    color: #888888;
    font-size: 13px;
    font-weight: bold;
}
#spaces_panel QPushButton {
    text-align: left;
    padding: 8px 12px;
    background: transparent;
    border-radius: 6px;
    color: #333333;
}
#spaces_panel QPushButton:hover {
    background-color: #f0eee8;
}
#spaces_panel QPushButton:checked, #spaces_panel QPushButton[active="true"] {
    background-color: #e6e4df;
    font-weight: bold;
}

/* 常规面板内的组件 */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #ffffff;
    border: 1px solid #d4d4d4;
    border-radius: 8px;
    padding: 10px 14px;
    color: #2b2b2b;
    selection-background-color: #eaddd3;
}
QLineEdit:focus, QTextEdit:focus {
    border-color: #cc6655;
}

/* 通用按钮 */
QPushButton {
    background-color: #cc6655;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #b55243;
}
QPushButton:pressed {
    background-color: #9c4538;
}

/* 次要按钮（比如取消、展开之类） */
QPushButton.secondary {
    background-color: #f0eee8;
    color: #444444;
    border: 1px solid #e5e3dd;
}
QPushButton.secondary:hover {
    background-color: #e6e4df;
}

/* 列表容器 */
QListWidget {
    background-color: #ffffff;
    border: 1px solid #e5e3dd;
    border-radius: 8px;
    outline: none;
}
QListWidget::item {
    padding: 10px 14px;
    border-bottom: 1px solid #faf9f7;
}
QListWidget::item:hover {
    background-color: #f9f8f6;
}
QListWidget::item:selected {
    background-color: #f0eee8;
    color: #cc6655;
    font-weight: bold;
    border-radius: 6px;
}

/* 滚动条更浅一些 */
QScrollBar:vertical {
    background: transparent;
    width: 6px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background-color: #dcdcdc;
    border-radius: 3px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover {
    background-color: #bcbcbc;
}
QScrollBar::add-line, QScrollBar::sub-line { height: 0; }

/* 拖拽隔断线 */
QSplitter::handle {
    background-color: #e5e3dd;
    width: 1px;
}
QSplitter::handle:hover {
    background-color: #cc6655;
}

/* 空白状态、小标题 */
QLabel.header {
    font-size: 16px;
    font-weight: bold;
    color: #2b2b2b;
}

/* 聊天气泡区域内底色透明 */
#chat_history_container {
    background-color: transparent;
}
